# Server Configuration
PORT=3000
NODE_ENV=development

# Database
# This project uses NeDB (file-based, embedded) by default — no external DB needed.
# Data files are stored under server/data/. No connection string is required.
# (MONGODB_URI is reserved for a future migration to MongoDB and is currently unused.)
# MONGODB_URI=mongodb://localhost:27017/speack3

# JWT Configuration
# IMPORTANT: generate strong random secrets before any non-local use, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_generate_a_long_random_secret
JWT_REFRESH_SECRET=change_me_generate_a_different_long_random_secret
JWT_EXPIRE=1h
JWT_REFRESH_EXPIRE=7d

# CORS Configuration
# Comma-separated list of allowed origins. Leave restrictive in production.
# If unset, the server falls back to '*' (development only — do NOT ship like this).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# SSL/TLS (for production behind your own Node TLS setup; usually handled by a
# reverse proxy such as nginx + Let's Encrypt instead)
SSL_KEY_PATH=./certs/private.key
SSL_CERT_PATH=./certs/certificate.crt
